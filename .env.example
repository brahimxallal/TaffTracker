# Template for Python-side environment variables.
# Copy to .env (gitignored) and fill as needed.
#
# Firmware WiFi credentials live separately in
#   firmware/esp32s3_gimbal/wifi_secrets.env
# (see firmware/esp32s3_gimbal/wifi_secrets.env.example)

# Example (not currently used by any Python module):
# TRACKER_LOG_LEVEL=INFO
# TRACKER_CONFIG_PATH=config.yaml
